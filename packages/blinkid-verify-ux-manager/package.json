{
  "name": "@microblink/blinkid-verify-ux-manager",
  "description": "BlinkID Verify UX Manager provides user feedback based on the blinkid-verify process results.",
  "version": "3.20.0",
  "author": "Microblink",
  "scripts": {
    "build": "concurrently pnpm:build:js pnpm:build:types",
    "build:dev": "concurrently pnpm:build:js-dev pnpm:build:types",
    "build:js": "vite build --mode ${VITE_BUILD_MODE:-production}",
    "build:js-dev": "vite build --mode development",
    "build:publish": "pnpm build && pnpm type-rollup",
    "build:types": "tsc",
    "clean": "rimraf .turbo types dist publish public/resources/* *.tgz",
    "docs:api": "typedoc",
    "pack-check": "pnpm pack | tail -n1 | xargs attw --profile esm-only && publint publish",
    "prepack": "pnpm prepare-publish",
    "prepare-publish": "tsx scripts/prepare-publish.mts",
    "publish-test": "pnpm build:publish && pnpm pack-check",
    "type-rollup": "api-extractor run --local"
  },
  "publishConfig": {
    "directory": "publish",
    "linkDirectory": false
  },
  "files": [
    "dist",
    "types"
  ],
  "type": "module",
  "main": "./dist/blinkid-verify-ux-manager.js",
  "module": "./dist/blinkid-verify-ux-manager.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/blinkid-verify-ux-manager.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@microblink/blinkid-verify-core": "workspace:^",
    "@microblink/camera-manager": "workspace:^",    
    "clsx": "^2.1.1",
    "merge-anything": "^6.0.3",
    "perfect-debounce": "^2.1.0",
    "solid-motionone": "^1.0.3",
    "ts-pattern": "^5.6.2",
    "type-fest": "^4.35.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@microblink/feedback-stabilizer": "workspace:^",
    "@microblink/ux-common": "workspace:^",
    "@microblink/shared-components": "workspace:^",
    "@microblink/tsconfig": "workspace:*",
    "@microblink/unocss-config": "workspace:*",
    "@microblink/repo-utils": "workspace:*",
    "@microsoft/api-extractor": "^7.52.4",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@unocss/eslint-config": "^66.6.5",
    "@unocss/preset-uno": "^66.6.5",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-define-config": "^1.24.1",
    "eslint-plugin-solid": "0.14.5",
    "prettier-plugin-classnames": "0.9.0",
    "publint": "^0.3.12",
    "rimraf": "^6.0.1",
    "sass": "^1.85.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.7",
    "typedoc-plugin-markdown": "^4.7.0",
    "typescript": "5.8.3",
    "unocss": "^66.6.5",
    "vite": "^6.2.1",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-externalize-dependencies": "1.0.1",
    "vite-plugin-solid": "^2.11.10",
    "vite-plugin-solid-svg": "0.8.1",
    "vitest": "^3.0.8",
    "write-package": "^7.1.0",
    "zx": "^8.8.5"
  },
  "peerDependencies": {
    "@ark-ui/solid": "^5.30.0",
    "@solid-primitives/keyed": "^1.5.2",
    "solid-js": "^1.9.11",
    "solid-zustand": "^1.8.1"
  },
  "keywords": [
    "aml",
    "blinkid-verify",
    "blinkid-verify",
    "compliance",
    "computer-vision",
    "document-authentification",
    "document-scanner",
    "document-verification",
    "driver-license",
    "fraud-detection",
    "frontend",
    "id-check",
    "id-verification",
    "image-processing",
    "kyc",
    "microblink",
    "ocr",
    "passport-verification",
    "typescript",
    "verification",
    "verify",
    "video",
    "wasm",
    "webassembly"
  ],
  "license": "ISC"
}
