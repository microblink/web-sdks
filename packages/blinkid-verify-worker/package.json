{
  "name": "@microblink/blinkid-verify-worker",
  "description": "Provides a worker which runs the BlinkID WebAssembly in separate thread",
  "private": true,
  "version": "3.20.0",
  "scripts": {
    "build": "concurrently pnpm:build:js pnpm:build:types",
    "build:dev": "concurrently pnpm:build:js-dev pnpm:build:types",
    "build:js": "vite build",
    "build:js-dev": "vite build --mode development",
    "build:publish": "pnpm build",
    "build:types": "tsc",
    "clean": "rimraf .turbo types dist public/resources/*",
    "lint": "pnpm run lint:types",
    "lint:types": "tsc --emitDeclarationOnly false --noEmit",
    "docs:api": "typedoc",
    "watch": "concurrently pnpm:watch:js pnpm:watch:types",
    "watch:js": "vite build --mode development --watch",
    "watch:types": "tsc --watch"
  },
  "main": "dist/blinkid-verify-worker.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./dist/blinkid-verify-worker.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "types"
  ],
  "dependencies": {
    "@microblink/analytics": "workspace:^",
    "@microblink/blinkid-verify-wasm": "workspace:*",
    "@microblink/worker-common": "workspace:*",
    "comlink": "^4.4.2",
    "merge-anything": "^6.0.3"
  },
  "devDependencies": {
    "@microblink/tsconfig": "workspace:*",
    "@microblink/repo-utils": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-define-config": "^1.24.1",
    "rimraf": "^6.0.1",
    "typedoc": "^0.28.7",
    "typedoc-plugin-markdown": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "vite": "^6.2.1",
    "vitest": "^3.0.8",
    "zx": "^8.8.5"
  }
}
