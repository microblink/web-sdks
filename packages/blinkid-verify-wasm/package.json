{
  "name": "@microblink/blinkid-verify-wasm",
  "private": true,
  "version": "3.20.0",
  "scripts": {
    "build": "tsc",
    "build:publish": "tsc",
    "clean": "rimraf .turbo types",
    "docs:api": "typedoc",
    "lint": "pnpm lint:types",
    "lint:types": "tsc --emitDeclarationOnly false --noEmit"
  },
  "type": "module",
  "main": "src/index.ts",
