  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./size-manifest.json": "./dist/size-manifest.json",
    "./package.json": "./package.json"
  },
  "imports": {
    "#BlinkIdVerifyModule": "./dist/advanced/BlinkIdVerifyModule.js",
