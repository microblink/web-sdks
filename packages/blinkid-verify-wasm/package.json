    "prettier-plugin-jsdoc": "^1.3.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.7",
    "typedoc-plugin-markdown": "^4.7.0",
    "typescript": "5.8.3",
    "vite": "^6.2.1",
    "vitest": "^4.0.8",
