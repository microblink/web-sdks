  },
  "files": [
    "dist",
    "types"
  ],
  "devDependencies": {
    "@microblink/tsconfig": "workspace:*",
    "@microblink/wasm-common": "workspace:*",
    "@vitest/browser-playwright": "^4.0.8",
    "arktype": "^2.2.0",
    "dotenv-cli": "^8.0.0",
