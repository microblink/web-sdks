{
  "name": "@microblink/blinkid-verify-core",
  "description": "BlinkID Verify Core SDK",
  "version": "3.20.0",
  "author": "Microblink",
  "scripts": {
    "build": "concurrently pnpm:build:js pnpm:build:types",
    "build:js": "vite build --mode ${VITE_BUILD_MODE:-production}",
    "build:js-dev": "vite build --mode development",
    "build:publish": "pnpm build && pnpm type-rollup",
    "build:types": "tsc",
    "clean": "rimraf .turbo types dist publish public/resources/* *.tgz",
    "docs:api": "typedoc",
    "lint": "concurrently pnpm:lint:types pnpm:lint:eslint",
    "lint:eslint": "eslint ./src --max-warnings 0",
    "lint:types": "tsc --emitDeclarationOnly false --noEmit",
    "pack-check": "pnpm pack | tail -n1 | xargs attw --profile esm-only && publint publish",
    "prepack": "pnpm prepare-publish",
    "prepare-publish": "tsx scripts/prepare-publish.mts",
    "publish-test": "pnpm build:publish && pnpm prepare-publish && pnpm pack-check",
    "type-rollup": "api-extractor run --local",
    "watch": "concurrently pnpm:watch:js pnpm:watch:types",
    "watch:js": "pnpm run build:js --watch --mode development",
    "watch:types": "pnpm run build:types --watch"
  },
  "type": "module",
  "main": "./dist/blinkid-verify-core.js",
  "module": "./dist/blinkid-verify-core.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/blinkid-verify-core.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "directory": "publish",
    "linkDirectory": false
  },
  "files": [
    "dist",
    "types"
  ],
  "dependencies": {
    "@microblink/analytics": "workspace:*",
    "@microblink/blinkid-verify-wasm": "workspace:*",
    "@microblink/blinkid-verify-worker": "workspace:*",
    "@microblink/core-common": "workspace:*",
    "comlink": "^4.4.2",
    "common-tags": "^1.8.2",
    "type-fest": "^4.35.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@microblink/repo-utils": "workspace:*",
    "@microblink/test-utils": "workspace:*",
    "@microblink/tsconfig": "workspace:*",
    "@microblink/wasm-common": "workspace:*",
    "@microblink/worker-common": "workspace:*",
    "@microsoft/api-extractor": "^7.52.4",
    "@types/common-tags": "^1.8.3",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "@vitest/browser": "^3.0.8",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-define-config": "^1.24.1",
    "playwright": "^1.51.0",
    "publint": "^0.3.12",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.7",
    "typedoc-plugin-markdown": "^4.7.0",
    "typescript": "5.8.3",
    "vite": "^6.2.1",
    "vitest": "^3.0.8",
    "write-package": "^7.1.0",
    "zx": "^8.8.5"
  },
  "keywords": [
    "aml",
    "blinkid-verify",
    "blinkid",
    "compliance",
    "computer-vision",
    "document-authentification",
    "document-scanner",
    "document-verification",
    "driver-license",
    "fraud-detection",
    "frontend",
    "id-check",
    "id-verification",
    "image-processing",
    "kyc",
    "microblink",
    "ocr",
    "passport-verification",
    "typescript",
    "verification",
    "verify",
    "video",
    "wasm",
    "webassembly"
  ],
  "license": "ISC"
}
