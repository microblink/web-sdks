{
  "name": "@microblink/test-utils",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "lint": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./mocks": {
      "types": "./src/mocks/index.ts",
      "default": "./src/mocks/index.ts"
    },
    "./mocks/imageData": {
      "types": "./src/mocks/imageData.ts",
      "default": "./src/mocks/imageData.ts"
    },
    "./mocks/licensing": {
      "types": "./src/mocks/licensing.ts",
      "default": "./src/mocks/licensing.ts"
    },
    "./mocks/scanningSession": {
      "types": "./src/mocks/scanningSession.ts",
      "default": "./src/mocks/scanningSession.ts"
    },
    "./mocks/wasmModuleFactory": {
      "types": "./src/mocks/wasmModuleFactory.ts",
      "default": "./src/mocks/wasmModuleFactory.ts"
    },
    "./vitest": {
      "types": "./src/vitest/index.ts",
      "default": "./src/vitest/index.ts"
    },
    "./vitest/timers": {
      "types": "./src/vitest/timers.ts",
      "default": "./src/vitest/timers.ts"
